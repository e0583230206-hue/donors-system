PORT=3000

# JWT secret — ייצר עם הפקודה:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET

# API key עבור טכנוליין IVR — כל מחרוזת אקראית חזקה
IVR_KEY=REPLACE_WITH_STRONG_IVR_KEY

# מזהה הטרמינל לתשלום כרטיס אשראי (Nedarim Plus / טכנוליין creditCard)
# קבל מטכנוליין ולאחר מכן בטל הערה ב-ivr.js ל-creditCard
CREDIT_CARD_TERMINAL=

# Technoline Click-to-Call (חייג לתורם מהכרטיס)
# API Key של חשבון טכנוליין — קבל מצוות הפיתוח של טכנוליין
TECHNOLINE_API_KEY=
# שלוחת ברירת מחדל (ניתן לדרוס בגוף הבקשה מה-frontend)
TECHNOLINE_AGENT_EXTENSION=
# שלוחת ברירת המחדל להפעלת IVR מתוך קמפיין (אם ריק, הקוד נופל לברירת
# המחדל הקשיחה "9263" ב-server.js)
TECHNOLINE_IVR_EXTENSION=
# מזהה רשימת התפוצה בטכנוליין לסנכרון מספרים מאושרים (settings.html "סנכרון תפוצה")
TECHNOLINE_MAILING_LIST_ID=

# ניסוי הקלטות IVR (fileLink/fileName) — שלוחת בדיקה נפרדת לחלוטין מ-9263.
# ivr-audio-trial.route.js. שני המשתנים חייבים להיות מוגדרים יחד, אחרת ה-route
# נכשל תמיד ב-403 (fail closed). אין ברירת מחדל ל-9263 בכוונה.
# מפתח נפרד לחלוטין מ-IVR_KEY — לעולם אל תשתמש באותו ערך.
IVR_AUDIO_TRIAL_KEY=
# מספר שלוחת הבדיקה שתפתח אצל טכנוליין (Remote URL נפרד, לא 9263)
TECHNOLINE_IVR_TRIAL_EXTENSION=
# מספר הטלפון היחיד שמשתמש בהקלטות כש-IVR_AUDIO_MODE=trial (ראו
# ivr-audio-mode.service.js / ivr-audio-context.service.js) — כל מתקשר אחר
# ממשיך ב-TTS הרגיל בלי קשר לערך הזה. ריק כברירת מחדל = אין שום שינוי
# בזרימה לאף מתקשר. לעולם אל תכניס מספר אמיתי כאן או ב-git — רק ב-.env
# הפעיל בשרת.
# (הבייפס הזמני שהיה כאן — מעבר ישיר להשמעת DEBT-002 בעקיפת הזרימה
# האמיתית, shouldTriggerTrialTransfer/buildTrialTransferResponse — הוסר;
# המשתנה עצמו נשאר, בתפקיד חדש כשער ל-mode=trial.)
IVR_AUDIO_TRIAL_CALLER_PHONE=

# מצב שימוש בהקלטות IVR מוקלטות מראש (ivr-audio-mode.service.js). ערך חסר
# או לא חוקי = off. off=TTS לכולם (התנהגות נוכחית). trial=רק המספר ב-
# IVR_AUDIO_TRIAL_CALLER_PHONE. on=כל השיחות. נכון לעכשיו לא מחובר בפועל
# ל-ivr.js — התשתית קיימת, ההפעלה בזרימה החיה תהיה שלב נפרד.
IVR_AUDIO_MODE=
# בסיס URL ציבורי שממנו טכנוליין מושכת קבצי fileLink. ריק = נופל לברירת
# המחדל הקשיחה ב-ivr-audio-resolver.service.js (https://30206.co.il/uploads/ivr-audio).
IVR_AUDIO_PUBLIC_BASE_URL=

# מצב שימוש בהודעות systemMessages המוקלטות של מודול הסליקה (S3000-S3023,
# PAYMSG-3000..3023) — נפרד לגמרי מ-IVR_AUDIO_MODE שמעליו, ואינו מושפע
# ממנו ואינו משפיע עליו. ערך חסר/לא חוקי = off. off=creditCard רגיל בלי
# systemMessages (התנהגות נוכחית). trial=רק המספר ב-
# IVR_AUDIO_PAYMSG_TRIAL_CALLER_PHONE. on=כל השיחות. ראו
# docs/ivr-audio/ivr-audio-paymsg-v1.0-DRAFT.md §9.
IVR_AUDIO_PAYMSG_MODE=
# מספר הטלפון היחיד שמשתמש בהודעות PAYMSG כש-IVR_AUDIO_PAYMSG_MODE=trial —
# נפרד מ-IVR_AUDIO_TRIAL_CALLER_PHONE הרגיל, יכול להיות זהה או שונה, לבחירתך.
# לעולם אל תכניס מספר אמיתי כאן או ב-git — רק ב-.env בשרת.
IVR_AUDIO_PAYMSG_TRIAL_CALLER_PHONE=

# SIP (softphone — frontend/softphone.html)
SIP_SERVER=
SIP_EXT=
SIP_USER=
SIP_PASS=

# AI Assistant (frontend/js/ai-assistant.js + backend/ai/) — אופציונלי.
# אם ריק, המערכת נופלת אוטומטית ל-engine מקומי (ai/engines/local.js) ללא AI חיצוני.
OPENAI_API_KEY=
# מודל OpenAI לשימוש — אם ריק, הקוד נופל לברירת המחדל gpt-4o-mini
OPENAI_MODEL=

# רמת מינימום ללוגים: debug | info | warn | error
LOG_LEVEL=info
# הצגת ערכים גולמיים (לא-מוסתרים) בלוגי logger.js גם ב-NODE_ENV=production —
# אזהרה: אל תפעיל בסביבת ייצור אלא לזמן קצר ומבוקר לצורך דיבוג ספציפי, ותכבה מיד אחרי.
LOG_DEBUG=false

# הצגת פרמטרי שאילתת IVR גולמיים (טלפונים/סכומים) בלוגים גם ב-NODE_ENV=production —
# אזהרה: אל תפעיל בסביבת ייצור אלא לזמן קצר ומבוקר לצורך דיבוג ספציפי, ותכבה מיד אחרי.
IVR_DEBUG=false
# מאפשר גישה ל-/ivr גם ללא IVR_KEY מוגדר — אזהרה: מיועד אך ורק לבדיקות
# מקומיות. לעולם אל תפעיל ב-Production — זה פותח את ה-IVR לכל אחד ללא אימות.
ALLOW_INSECURE_IVR=false

# Alfon API — משיכת תורמים מאושרים מ-utilitiesphone.com (server.js "Alfon API fetch")
# אם ריק, הקוד נופל לברירת מחדל קשיחה ב-server.js (ה-URL הרגיל של השירות) — זו
# החלטה מכוונת, לא סוד; הגדר כאן רק אם צריך לכוון לסביבה/URL אחר.
ALFON_API_URL=
# מפתח שנדרש ב-POST /api/sync/alfon-auto (הדר x-alfon-key) — בלעדיו הנתיב מחזיר 503
ALFON_SYNC_KEY=

# שעות תוקף לסשן
SESSION_TIMEOUT_HOURS=8

# סביבת הרצה: development | production
NODE_ENV=production

# נתיב בסיס נתונים (יחסי לתיקיית backend)
DB_PATH=data.sqlite
