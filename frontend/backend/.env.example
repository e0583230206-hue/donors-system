PORT=3000

# JWT secret — ייצר עם הפקודה:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_64_CHAR_SECRET

# API key עבור טכנוליין IVR — כל מחרוזת אקראית חזקה
IVR_KEY=REPLACE_WITH_STRONG_IVR_KEY

# מזהה הטרמינל לתשלום כרטיס אשראי (Nedarim Plus / טכנוליין creditCard)
# קבל מטכנוליין ולאחר מכן בטל הערה ב-ivr.js ל-creditCard
CREDIT_CARD_TERMINAL=

# Technoline Click-to-Call (חייג לתורם מהכרטיס)
# API Key של חשבון טכנוליין — קבל מצוות הפיתוח של טכנוליין
TECHNOLINE_API_KEY=
# שלוחת ברירת מחדל (ניתן לדרוס בגוף הבקשה מה-frontend)
TECHNOLINE_AGENT_EXTENSION=

# שעות תוקף לסשן
SESSION_TIMEOUT_HOURS=8

# סביבת הרצה: development | production
NODE_ENV=production

# נתיב בסיס נתונים (יחסי לתיקיית backend)
DB_PATH=data.sqlite
